        <mxCell id="r-auth" value="auth.py&#xa;POST /auth/register  → 註冊&#xa;POST /auth/login     → JWT 登入&#xa;GET  /auth/me        → 個人資訊&#xa;PUT  /auth/me/update → 更新資料&#xa;GET  /auth/me/token-usage&#xa;POST /auth/me/forgot-password" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
          <mxGeometry x="12" y="48" width="418" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r-sso" value="sso.py&#xa;GET  /auth/sso/login    → SSO 跳轉&#xa;GET  /auth/sso/callback → ticket 驗證&#xa;POST /auth/sso/login    → Mock SSO" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
          <mxGeometry x="450" y="48" width="418" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r-jobs" value="jobs.py&#xa;POST   /jobs        → 提交任務 (扣 Token)&#xa;GET    /jobs        → 列表 (RBAC)&#xa;GET    /jobs/{id}   → 狀態查詢&#xa;DELETE /jobs/{id}   → 取消&#xa;GET    /jobs/{id}/stream → SSE 串流" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
          <mxGeometry x="12" y="215" width="418" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r-chat" value="chat.py&#xa;POST /chat/completions → SSE 串流&#xa;  (proxy to Portkey LLM Gateway)&#xa;GET  /chat/history     → 對話歷史&#xa;GET  /chat/sessions    → session 清單" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
          <mxGeometry x="450" y="215" width="418" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r-worker" value="worker.py&#xa;POST /worker/take           → 原子領取任務&#xa;POST /worker/jobs/{id}/update → 回報進度&#xa;POST /worker/heartbeat      → 節點心跳&#xa;Auth: hmac.compare_digest Bearer Token" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
          <mxGeometry x="12" y="385" width="418" height="125" as="geometry" />
        </mxCell>
        <mxCell id="r-admin" value="admin.py&#xa;GET  /admin/users               → JOIN 查詢+分頁&#xa;PUT  /admin/users/{id}          → 更新使用者&#xa;PUT  /admin/users/batch/tokens  → 批量 Token&#xa;POST /admin/users/{id}/delete   → 刪除&#xa;POST /admin/users/{id}/reset    → 重置&#xa;POST /admin/users/provision     → 配發帳號&#xa;POST /admin/verify              → 密碼驗證&#xa;GET  /admin/jobs                → 任務列表&#xa;POST /admin/jobs/{id}/cancel    → 強制取消&#xa;PUT  /admin/jobs/{id}/priority  → 優先級&#xa;CRUD /admin/models              → 模型管理&#xa;GET  /admin/cluster/stats       → GPU 節點狀態&#xa;GET  /admin/analytics           → 數據分析" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
          <mxGeometry x="450" y="385" width="418" height="305" as="geometry" />
        </mxCell>
        <mxCell id="r-datasets" value="datasets.py&#xa;POST /datasets/upload → 上傳資料集&#xa;GET  /datasets/list   → 列出資料集&#xa;儲存路徑: /data/datasets/{user_id}/" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#140202;strokeColor=#c62828;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="routers-g">
