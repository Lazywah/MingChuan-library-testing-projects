        <mxCell id="f4-p4" value="SQLite DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#041804;strokeColor=#4caf50;fontSize=13;fontStyle=1;fontColor=#a5d6a7;" vertex="1" parent="1">
          <mxGeometry x="2520" y="1188" width="115" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f4-p5" value="Portkey Gateway&#xa;(:8000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0e0e2e;strokeColor=#3949ab;fontSize=13;fontStyle=1;fontColor=#c5cae9;" vertex="1" parent="1">
          <mxGeometry x="2756" y="1188" width="140" height="48" as="geometry" />
