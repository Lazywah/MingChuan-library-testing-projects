        <mxCell id="f4-title" value="④ AI 聊天串流流程  POST /api/v1/chat/completions" style="text;html=1;strokeColor=#5c6bc0;fillColor=#0e0e2e;align=left;fontSize=14;fontStyle=1;spacingLeft=12;fontColor=#c5cae9;" vertex="1" parent="1">
          <mxGeometry x="1740" y="1134" width="1400" height="36" as="geometry" />
        </mxCell>

        <!-- Participants row 4 -->
        <mxCell id="f4-p1" value="Browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1e38;strokeColor=#4a90e2;fontSize=13;fontStyle=1;fontColor=#90caf9;" vertex="1" parent="1">
          <mxGeometry x="1760" y="1188" width="115" height="48" as="geometry" />
