        <mxCell id="f4-p2" value="chat.py (Router)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1e38;strokeColor=#4a90e2;fontSize=13;fontStyle=1;fontColor=#90caf9;" vertex="1" parent="1">
