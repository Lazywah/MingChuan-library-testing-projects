        </mxCell>
        <mxCell id="f5-note3" value="map to AdminUserListItem list&#xa;tokens_used = t.tokens_used if t else 0" style="text;html=1;strokeColor=#5c6bc0;fillColor=#0e0e2e;fontSize=11;fontColor=#c5cae9;" vertex="1" parent="1">
