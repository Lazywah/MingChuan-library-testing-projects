        </mxCell>
        <mxCell id="f6-note1" value="for job in all_running:&#xa;  started = job.started_at&#xa;  if started.tzinfo is None:&#xa;    started = started.replace(tzinfo=utc)&#xa;  if started &lt; cutoff (now - 120 min):&#xa;    stuck_jobs.append(job)" style="text;html=1;strokeColor=#8e44c2;fillColor=#14102a;fontSize=11;align=left;fontColor=#d7bcf7;" vertex="1" parent="1">
          <mxGeometry x="14" y="2252" width="370" height="138" as="geometry" />
        </mxCell>
        <mxCell id="f6-m3" value="UPDATE training_jobs SET status='failed',&#xa;  error_message='Timeout: ...'&#xa;WHERE id IN stuck_jobs" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d32f2f;fontColor=#ff8a80;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
