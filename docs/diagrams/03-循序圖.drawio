        <mxCell id="f6-title" value="⑥ Scheduler 超時清理  _cleanup_timed_out_jobs()  (背景迴圈每 5 分鐘)" style="text;html=1;strokeColor=#8e44c2;fillColor=#14102a;align=left;fontSize=14;fontStyle=1;spacingLeft=12;fontColor=#d7bcf7;" vertex="1" parent="1">
