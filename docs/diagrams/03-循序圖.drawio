        </mxCell>
        <mxCell id="f5-note1" value="if user.role != 'admin': raise HTTP 403" style="text;html=1;strokeColor=#d32f2f;fillColor=#200808;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1684" width="320" height="32" as="geometry" />
