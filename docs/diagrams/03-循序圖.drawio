        <mxCell id="f5-m2r" value="current_user (admin)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ef5350;fontColor=#ff8a80;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="644" y="1728"/><mxPoint as="targetPoint" x="374" y="1728"/></mxGeometry>
        </mxCell>
        <mxCell id="f5-note2" value="單次 JOIN 查詢 (消除 N+1):&#xa;SELECT users, token_usage&#xa;FROM users&#xa;LEFT OUTER JOIN token_usage&#xa;  ON token_usage.user_id = users.id&#xa;ORDER BY users.created_at DESC&#xa;OFFSET 0 LIMIT 20" style="text;html=1;strokeColor=#4caf50;fillColor=#041804;fontSize=11;align=left;fontColor=#a5d6a7;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1745" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="f5-m3" value="Single JOIN query" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="374" y="1826"/><mxPoint as="targetPoint" x="898" y="1826"/></mxGeometry>
        </mxCell>
        <mxCell id="f5-m3r" value="[(User, TokenUsage), ...] 20 rows" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
