          <mxGeometry x="3024" y="1188" width="155" height="48" as="geometry" />
        </mxCell>

        <!-- Lifelines 4 -->
        <mxCell id="f4-l1" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#4a90e2;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1818" y="1236"/><mxPoint as="targetPoint" x="1818" y="1830"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-l2" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#4a90e2;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2078" y="1236"/><mxPoint as="targetPoint" x="2078" y="1830"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-l3" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#4a90e2;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2338" y="1236"/><mxPoint as="targetPoint" x="2338" y="1830"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-l4" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#4caf50;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2578" y="1236"/><mxPoint as="targetPoint" x="2578" y="1830"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-l5" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#3949ab;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2826" y="1236"/><mxPoint as="targetPoint" x="2826" y="1830"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-l6" value="" style="endArrow=none;html=1;dashed=1;strokeColor=#ad1457;strokeWidth=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="3102" y="1236"/><mxPoint as="targetPoint" x="3102" y="1830"/></mxGeometry>
        </mxCell>

        <!-- Message sequence 4 -->
        <mxCell id="f4-m1" value="POST /chat/completions  Bearer &lt;JWT&gt;  {model_id:'claude-opus-4', messages:[...], session_id}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c8d8f8;fontColor=#c8d8f8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1818" y="1278"/><mxPoint as="targetPoint" x="2078" y="1278"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-m1a" value="get_current_user(JWT)  →  current_user" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c8d8f8;fontColor=#c8d8f8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2078" y="1314"/><mxPoint as="targetPoint" x="2338" y="1314"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-m2" value="get_token_usage(db, user_id)  → check quota" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2078" y="1352"/><mxPoint as="targetPoint" x="2578" y="1352"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-note1" value="tokens_used &gt;= tokens_limit ?&#xa;→ SSE error: 'Token quota exceeded'" style="text;html=1;strokeColor=#d32f2f;fillColor=#200808;fontSize=11;fontColor=#ff8a80;" vertex="1" parent="1">
          <mxGeometry x="1978" y="1367" width="290" height="46" as="geometry" />
        </mxCell>
        <mxCell id="f4-note2" value="_get_portkey_headers('claude-opus-4')&#xa;→ x-portkey-provider: anthropic" style="text;html=1;strokeColor=#5c6bc0;fillColor=#0e0e2e;fontSize=11;fontColor=#c5cae9;" vertex="1" parent="1">
          <mxGeometry x="1978" y="1425" width="300" height="46" as="geometry" />
        </mxCell>
        <mxCell id="f4-m3" value="httpx.AsyncClient.stream()  POST http://portkey:8000/v1/chat/completions" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#5c6bc0;fontColor=#c5cae9;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2078" y="1484"/><mxPoint as="targetPoint" x="2826" y="1484"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-m4" value="forward to Anthropic API" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ad1457;fontColor=#f48fb1;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2826" y="1520"/><mxPoint as="targetPoint" x="3102" y="1520"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-m5" value="data: {delta: 'Hello'} (SSE chunk 1)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ad1457;fontColor=#f48fb1;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="3102" y="1558"/><mxPoint as="targetPoint" x="2826" y="1558"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-m6" value="yield f'data: {chunk}' → StreamingResponse" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#5c6bc0;fontColor=#c5cae9;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2826" y="1594"/><mxPoint as="targetPoint" x="1818" y="1594"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-note3" value="...多個 SSE chunks..." style="text;html=1;strokeColor=#555555;fillColor=#141414;fontSize=11;align=center;fontStyle=2;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="1978" y="1612" width="300" height="28" as="geometry" />
        </mxCell>
        <mxCell id="f4-m7" value="data: [DONE]" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ad1457;fontColor=#f48fb1;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="3102" y="1652"/><mxPoint as="targetPoint" x="1818" y="1652"/></mxGeometry>
        </mxCell>
        <mxCell id="f4-note4" value="stream 結束後 (非同步)：&#xa;1. db.add(ChatHistory user)&#xa;2. db.add(ChatHistory assistant)&#xa;3. usage.tokens_used += total_tokens&#xa;4. user.lifetime_tokens_used += total_tokens&#xa;5. db.commit()  (single transaction)" style="text;html=1;strokeColor=#4caf50;fillColor=#041804;fontSize=11;align=left;fontColor=#a5d6a7;" vertex="1" parent="1">
          <mxGeometry x="1978" y="1670" width="340" height="130" as="geometry" />
        </mxCell>

        <!-- =====================================================================
             FLOW 5: Admin 查看使用者  (left half, below flow 2)
             ===================================================================== -->
        <mxCell id="f5-title" value="⑤ 管理員查詢使用者清單  GET /api/v1/admin/users  (JOIN 查詢 / require_admin)" style="text;html=1;strokeColor=#c62828;fillColor=#200404;align=left;fontSize=14;fontStyle=1;spacingLeft=12;fontColor=#ff8a80;" vertex="1" parent="1">
          <mxGeometry x="14" y="1440" width="1400" height="36" as="geometry" />
        </mxCell>

        <!-- Participants row 5 -->
        <mxCell id="f5-p1" value="Admin Browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#200404;strokeColor=#c62828;fontSize=13;fontStyle=1;fontColor=#ff8a80;" vertex="1" parent="1">
          <mxGeometry x="42" y="1494" width="130" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f5-p2" value="admin.py (Router)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#200404;strokeColor=#c62828;fontSize=13;fontStyle=1;fontColor=#ff8a80;" vertex="1" parent="1">
          <mxGeometry x="296" y="1494" width="155" height="48" as="geometry" />
        </mxCell>
        <mxCell id="f5-p3" value="require_admin()&#xa;Depends" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#200404;strokeColor=#c62828;fontSize=13;fontStyle=1;fontColor=#ff8a80;" vertex="1" parent="1">
