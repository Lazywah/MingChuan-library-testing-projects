        <!-- HEARTBEAT sub-flow -->
        <mxCell id="f3-sec1" value="【心跳上報 Heartbeat  — 每 30 秒】" style="text;html=1;strokeColor=#00838f;fillColor=#041a1a;fontSize=12;fontStyle=2;fontColor=#80deea;" vertex="1" parent="1">
          <mxGeometry x="1760" y="212" width="480" height="32" as="geometry" />
        </mxCell>

        <mxCell id="f3-m1" value="POST /worker/heartbeat  {node_id, available_gpus:[0,1], gpu_utilization:45.2}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00838f;fontColor=#80deea;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1825" y="258"/><mxPoint as="targetPoint" x="2094" y="258"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m1a" value="hmac.compare_digest(token, expected)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9c27b0;fontColor=#ce93d8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="292"/><mxPoint as="targetPoint" x="2366" y="292"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m1b" value="upsert_worker_heartbeat(db, node_id, gpus, util)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c8d8f8;fontColor=#c8d8f8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="326"/><mxPoint as="targetPoint" x="2618" y="326"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m1c" value="INSERT OR UPDATE worker_heartbeats" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2618" y="360"/><mxPoint as="targetPoint" x="2858" y="360"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m1r" value="200 {status:'ok', node_id}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="396"/><mxPoint as="targetPoint" x="1825" y="396"/></mxGeometry>
        </mxCell>

        <!-- TAKE JOB sub-flow -->
        <mxCell id="f3-sec2" value="【領取任務 Take Job  — 每 5 秒輪詢】" style="text;html=1;strokeColor=#00838f;fillColor=#041a1a;fontSize=12;fontStyle=2;fontColor=#80deea;" vertex="1" parent="1">
          <mxGeometry x="1760" y="428" width="480" height="32" as="geometry" />
        </mxCell>

        <mxCell id="f3-m2" value="get_available_gpus() → nvidia-smi&#xa;util[0]=3%, util[1]=80%  → [0] available" style="text;html=1;strokeColor=#00838f;fillColor=#041a1a;fontSize=11;align=left;fontColor=#80deea;" vertex="1" parent="1">
          <mxGeometry x="1640" y="468" width="300" height="46" as="geometry" />
        </mxCell>
        <mxCell id="f3-m3" value="POST /worker/take  {node_id:'node-01', available_gpus:['0']}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00838f;fontColor=#80deea;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1825" y="524"/><mxPoint as="targetPoint" x="2094" y="524"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m3a" value="verify_worker_token()" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9c27b0;fontColor=#ce93d8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="558"/><mxPoint as="targetPoint" x="2366" y="558"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m4" value="get_pending_jobs(db) → ORDER BY priority DESC" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#c8d8f8;fontColor=#c8d8f8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="592"/><mxPoint as="targetPoint" x="2618" y="592"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m4a" value="SELECT training_jobs WHERE status='pending'..." style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2618" y="626"/><mxPoint as="targetPoint" x="2858" y="626"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m4r" value="[job-001, ...]" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2858" y="658"/><mxPoint as="targetPoint" x="2094" y="658"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-note1" value="原子搶佔 Atomic Claim:&#xa;UPDATE training_jobs SET status='running',&#xa;  gpu_server='node-01', gpu_id='0', started_at=now()&#xa;WHERE id=job-001 AND status='pending'&#xa;→ rowcount=0 ? already taken" style="text;html=1;strokeColor=#d32f2f;fillColor=#200808;fontSize=11;align=left;fontColor=#ff8a80;" vertex="1" parent="1">
          <mxGeometry x="1975" y="675" width="400" height="95" as="geometry" />
        </mxCell>
        <mxCell id="f3-m5" value="200 {job:{job_id, script_path, dataset_path, config, gpu_id}}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="782"/><mxPoint as="targetPoint" x="1825" y="782"/></mxGeometry>
        </mxCell>

        <!-- execute job -->
        <mxCell id="f3-sec3" value="【執行任務 Execute Job】" style="text;html=1;strokeColor=#6d4c41;fillColor=#1a100a;fontSize=12;fontStyle=2;fontColor=#d7ccc8;" vertex="1" parent="1">
          <mxGeometry x="1760" y="812" width="400" height="32" as="geometry" />
        </mxCell>
        <mxCell id="f3-m6" value="docker run --gpus device=0  pytorch/pytorch train.py" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6d4c41;fontColor=#d7ccc8;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1825" y="856"/><mxPoint as="targetPoint" x="3127" y="856"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m7" value="[stdout] Epoch 1/10 → parse_progress() → 10%" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6d4c41;fontColor=#d7ccc8;fontSize=11;endArrow=open;endFill=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="3127" y="898"/><mxPoint as="targetPoint" x="1825" y="898"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m8" value="POST /worker/jobs/{id}/update  {log:'Epoch 1/10', progress:10.0}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00838f;fontColor=#80deea;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1825" y="940"/><mxPoint as="targetPoint" x="2094" y="940"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m8a" value="append_job_log() + update_job_progress()" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="974"/><mxPoint as="targetPoint" x="2858" y="974"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-note2" value="...重複多輪直到 Epoch 10/10..." style="text;html=1;strokeColor=#555555;fillColor=#141414;fontSize=11;align=center;fontStyle=2;fontColor=#aaaaaa;" vertex="1" parent="1">
          <mxGeometry x="1640" y="994" width="360" height="32" as="geometry" />
        </mxCell>
        <mxCell id="f3-m9" value="POST /worker/jobs/{id}/update  {status:'completed', progress:100.0, output_path}" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00838f;fontColor=#80deea;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="1825" y="1040"/><mxPoint as="targetPoint" x="2094" y="1040"/></mxGeometry>
        </mxCell>
        <mxCell id="f3-m9a" value="update_job_status(status='completed', output_path=...)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="2094" y="1078"/><mxPoint as="targetPoint" x="2858" y="1078"/></mxGeometry>
        </mxCell>

        <!-- =====================================================================
             FLOW 4: 聊天串流  (right half, below flow 3)
