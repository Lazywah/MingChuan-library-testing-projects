        <mxCell id="f5-m1" value="GET /admin/users?skip=0&amp;limit=20  Authorization: Bearer &lt;admin_JWT&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ef5350;fontColor=#ff8a80;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="107" y="1582"/><mxPoint as="targetPoint" x="374" y="1582"/></mxGeometry>
        </mxCell>
        <mxCell id="f5-m2" value="Depends(require_admin)&#xa;→ Depends(get_current_user) → decode JWT" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ef5350;fontColor=#ff8a80;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="sourcePoint" x="374" y="1630"/><mxPoint as="targetPoint" x="644" y="1630"/></mxGeometry>
        </mxCell>
        <mxCell id="f5-m2a" value="SELECT users WHERE username=?" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=block;endFill=1;" edge="1" parent="1">
