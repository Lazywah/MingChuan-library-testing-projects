        <mxCell id="rel-u-tu" value="1      N&#xa;CASCADE DELETE" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#4caf50;fontColor=#a5d6a7;fontSize=11;endArrow=ERmany;startArrow=ERone;startFill=0;endFill=0;" edge="1" parent="1">
