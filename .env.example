# ==============================================================================
# ZH: AI 訓練平台 - 環境變數範例
# EN: AI Training Platform - Environment Variables Example
# ZH: 複製此檔案為 .env 並修改對應的值
# EN: Copy this file to .env and modify the values accordingly
# ==============================================================================

# ------------------------------------------------------------------------------
# ZH: Web UI 設定 | EN: Web UI Configuration
# ------------------------------------------------------------------------------
WEBUI_SECRET_KEY=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING # 轉 Ubuntu 時修改為 32+ 字元字串

# ------------------------------------------------------------------------------
# ZH: JWT 認證設定 | EN: JWT Authentication Configuration
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING # 轉 Ubuntu 時修改為 32+ 字元字串

# ------------------------------------------------------------------------------
# ZH: Worker 節點靜態 Token（需與 gpu-worker/docker-compose.yml 的 API_TOKEN 完全一致）
# EN: Worker node static token (must match API_TOKEN in gpu-worker/docker-compose.yml)
# ZH: 建議使用 openssl rand -hex 32 產生
# EN: Generate with: openssl rand -hex 32
# ------------------------------------------------------------------------------
WORKER_API_TOKEN=CHANGE_THIS_TO_A_SECURE_RANDOM_TOKEN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ------------------------------------------------------------------------------
# ZH: 資料庫設定 | EN: Database Configuration
# ------------------------------------------------------------------------------
DATABASE_PATH=/data/ai_platform.db

# ------------------------------------------------------------------------------
# ZH: Token 額度設定 | EN: Token Quota Configuration
# ------------------------------------------------------------------------------
DEFAULT_MONTHLY_TOKEN_LIMIT=5000000
TOKEN_RESET_DAY=1

# ------------------------------------------------------------------------------
# ZH: GPU 伺服器設定 | EN: GPU Server Configuration
# ------------------------------------------------------------------------------
GPU_MOCK_MODE=true # 轉 Ubuntu 時修改為 false
GPU_SERVER_1_HOST=192.168.1.100
GPU_SERVER_2_HOST=192.168.1.101
GPU_SERVER_USERNAME=gpu_admin
SSH_KEY_PATH=/root/.ssh/gpu_key

# ------------------------------------------------------------------------------
# ZH: 排程器設定 | EN: Scheduler Configuration
# ------------------------------------------------------------------------------
MAX_CONCURRENT_JOBS=4
JOB_CHECK_INTERVAL=10

# ------------------------------------------------------------------------------
# ZH: 雲端 LLM API Keys (Portkey 使用)
# EN: Cloud LLM API Keys (Used by Portkey)
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-placeholder
OPENAI_API_KEY=sk-placeholder
GOOGLE_API_KEY=placeholder
GAMMA_API_KEY=placeholder

# ------------------------------------------------------------------------------
# ZH: CORS 設定（正式上線時填入，開發時留空表示允許所有來源）
# EN: CORS allowed origins (fill in for production; leave empty to allow all in dev)
# ZH: 範例（逗號分隔）：CORS_ORIGINS=http://192.168.1.50,https://ai.school.edu.tw
# ------------------------------------------------------------------------------
CORS_ORIGINS=

# ------------------------------------------------------------------------------
# ZH: 日誌等級 | EN: Log Level
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# ZH: SMTP 郵件設定 (用於登入/密碼通知) | EN: SMTP Email Configuration
# ------------------------------------------------------------------------------
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ai-platform.local

# ------------------------------------------------------------------------------
# ZH: MYAI 帳號設定 (用於 headless 伺服器登入) | EN: MYAI Account Configuration
# ------------------------------------------------------------------------------
MYAI_ADMIN_EMAIL=
MYAI_ADMIN_PASSWORD=