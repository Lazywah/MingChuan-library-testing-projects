# ==============================================================================
# ZH: GPU Worker 環境變數範本
# EN: GPU Worker environment variable template
#
# ZH: 使用方式：複製此檔案為 .env，修改後執行 docker compose up -d
# EN: Usage: copy this file to .env, edit values, then run docker compose up -d
#
# ZH: ⚠️ 換主機時唯一必須修改的項目是 SERVICE_LAYER_URL
# EN: ⚠️ The ONLY value that must change when deploying to a new host is SERVICE_LAYER_URL
# ==============================================================================

# ── 服務層連線 (換主機唯一必改項) ────────────────────────────────────────────
# ZH: 服務層主機的 IP 與 Port（FastAPI 固定在 8002）
# EN: Service layer host IP and port (FastAPI is always on 8002)
SERVICE_LAYER_URL=http://192.168.1.50:8002

# ── 安全憑證 (正式部署必換) ───────────────────────────────────────────────────
# ZH: 必須與服務層 .env 的 WORKER_API_TOKEN 完全一致
# EN: Must match WORKER_API_TOKEN in the service layer .env exactly
API_TOKEN=mcu-secret-token

# ── 節點識別 ──────────────────────────────────────────────────────────────────
# ZH: 此節點在叢集儀表板中顯示的名稱，多台 GPU 工作站請各自命名
# EN: Name shown in the admin cluster dashboard; use unique names for multiple nodes
NODE_ID=gpu-node-01

# ── 輪詢設定 ──────────────────────────────────────────────────────────────────
# ZH: 向服務層領取任務的輪詢間隔（秒）
POLL_INTERVAL=5

# ZH: 向服務層回報心跳的間隔（秒）
HEARTBEAT_INTERVAL=30

# ── 儲存掛載 ──────────────────────────────────────────────────────────────────
# ZH: 宿主機上共享儲存區的路徑（SMB 掛載磁碟機，如 Z:\ 或 C:\storage）
# EN: Path to the shared storage on the Windows host (SMB mapped drive, e.g. Z:\ or C:\storage)
STORAGE_MOUNT_PATH=C:\storage
