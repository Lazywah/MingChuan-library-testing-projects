# ==============================================================================
# ZH: GPU Worker 環境變數範本
# EN: GPU Worker environment variable template
#
# ZH: 使用方式：複製此檔案為 .env，修改後執行 docker compose up -d
# EN: Usage: copy this file to .env, edit values, then run docker compose up -d
#
# ZH: ⚠️ 必須修改的項目（依平台而定）
# EN: ⚠️ Required changes (platform-dependent)
#
#   【Windows — Docker Desktop + WSL2 後端】
#     - SERVICE_LAYER_URL：改為服務層主機的真實 IP
#     - 其餘維持預設即可（STORAGE_MOUNT_PATH 保留 C:\storage）
#     - 前置需求：Docker Desktop 已啟用 WSL2 後端與 GPU 支援
#
#   【Linux (Ubuntu) — 推薦生產環境】
#     - SERVICE_LAYER_URL：改為服務層主機的真實 IP
#     - STORAGE_MOUNT_PATH：必須改為 Linux 掛載路徑（例如 /mnt/storage）
#       ⚠️ 保留 C:\storage 在 Linux 上會導致訓練容器無法掛載儲存而失敗
#     - 前置需求：宿主機需安裝 nvidia-container-toolkit
#       sudo apt-get install -y nvidia-container-toolkit
#       sudo nvidia-ctk runtime configure --runtime=docker
#       sudo systemctl restart docker
#
# ==============================================================================

# ── 服務層連線 (換主機唯一必改項) ────────────────────────────────────────────
# ZH: 服務層主機的 IP 與 Port（FastAPI 固定在 8002）
# EN: Service layer host IP and port (FastAPI is always on 8002)
SERVICE_LAYER_URL=http://192.168.1.50:8002

# ── 安全憑證 (正式部署必換) ───────────────────────────────────────────────────
# ZH: 必須與服務層 .env 的 WORKER_API_TOKEN 完全一致
# EN: Must match WORKER_API_TOKEN in the service layer .env exactly
API_TOKEN=mcu-secret-token

# ── 節點識別 ──────────────────────────────────────────────────────────────────
# ZH: 此節點在叢集儀表板中顯示的名稱，多台 GPU 工作站請各自命名
# EN: Name shown in the admin cluster dashboard; use unique names for multiple nodes
NODE_ID=gpu-node-01

# ── 輪詢設定 ──────────────────────────────────────────────────────────────────
# ZH: 向服務層領取任務的輪詢間隔（秒）
POLL_INTERVAL=5

# ZH: 向服務層回報心跳的間隔（秒）
HEARTBEAT_INTERVAL=30

# ── 儲存掛載 ──────────────────────────────────────────────────────────────────
# ZH: Worker 啟動訓練容器時，會將此路徑以 -v <STORAGE_MOUNT_PATH>:/workspace 掛入容器。
#     此路徑由「宿主機 Docker Daemon」解析，因此必須填入宿主機看得懂的絕對路徑。
# EN: When the worker spawns a training container, it mounts this path as
#     -v <STORAGE_MOUNT_PATH>:/workspace. The path is resolved by the HOST Docker daemon,
#     so it must be an absolute path valid on the host OS.
#
# ▶ Windows 宿主（Docker Desktop）：
#     使用 Windows 路徑，Docker Desktop 可直接掛載
#     範例：STORAGE_MOUNT_PATH=C:\storage
#           STORAGE_MOUNT_PATH=Z:\              （SMB 對應磁碟機代號）
#
# ▶ Linux 宿主（Ubuntu，推薦生產環境）：
#     ⚠️ 不可使用 C:\storage，必須改為 Linux 絕對路徑
#     範例：STORAGE_MOUNT_PATH=/mnt/storage
#           STORAGE_MOUNT_PATH=/data/shared
#
#     若共享儲存是 SMB/CIFS，先在宿主機掛載再填此路徑：
#       sudo mount -t cifs //192.168.1.x/share /mnt/storage \
#         -o username=USER,password=PASS,uid=1000,gid=1000
#
STORAGE_MOUNT_PATH=C:\storage
